{
 "manifest_version": 3,
 "name": "GoetheGrabber",
 "version": "3.0",
 "permissions": [
   "activeTab",
   "scripting",
   "storage"
 ],
 "host_permissions": [
   "https://www.goethe.de/*",
   "https://login.goethe.de/*",
   "https://*.paymentiq.io/*"
 ],
 "action": {
   "default_popup": "popup.html"
 },
 "content_scripts": [
   {
     "matches": [
       "https://www.goethe.de/*",
       "https://login.goethe.de/*",
       "https://*.paymentiq.io/*"
     ],
     "js": ["content.js"],
     "run_at": "document_idle",
     "all_frames": true
   }
 ]
}